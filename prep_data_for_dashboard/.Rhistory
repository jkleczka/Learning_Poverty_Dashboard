library(tidyverse)
library(scales)
# Filter to one country
df_country <- LP_filtered %>%
filter(countrycode == "BRA") %>%   # change country
arrange(year_assessment)
# Determine dynamic y-axis limits
y_min <- min(c(df_country$lp_all, df_country$ld_all, df_country$sd_all), na.rm = TRUE)
y_max <- max(c(df_country$lp_all, df_country$ld_all, df_country$sd_all), na.rm = TRUE)
# Add padding so lines aren't touching edges
padding <- (y_max - y_min) * 0.15
# Plot
p <- ggplot(df_country, aes(x = year_assessment)) +
geom_line(aes(y = lp_all, color = "Learning Poverty"), linewidth = 1.3) +
geom_line(aes(y = ld_all, color = "Learning Deprivation"), linewidth = 1.3) +
geom_line(aes(y = sd_all, color = "Schooling Deprivation"), linewidth = 1.3) +
geom_point(
aes(y = ld_all, shape = test),
size = 3.5,
stroke = 1,
color = "black"
) +
scale_color_manual(
values = c(
"Learning Poverty" = "#0072B2",
"Learning Deprivation" = "#D55E00",
"Schooling Deprivation" = "#009E73"
)
) +
scale_y_continuous(
labels = label_percent(scale = 1),
limits = c(y_min - padding, y_max + padding)
) +
labs(
title = unique(df_country$country_name),
subtitle = "Learning Poverty and its Components Over Time",
x = "Assessment Year",
y = "Share of Children (%)",
shape = "Assessment",
color = ""
) +
theme_classic(base_size = 14) +
theme(
legend.position = "bottom",
plot.title = element_text(face = "bold", size = 18)
)
p
# Filter to one country
df_country <- LP_filtered %>%
filter(countrycode == "BRA") %>%
arrange(year_assessment)
# Convert to long format for stacking
df_long <- df_country %>%
select(year_assessment, ld_all, sd_all) %>%
pivot_longer(
cols = c(ld_all, sd_all),
names_to = "component",
values_to = "value"
)
df_long$component <- recode(
df_long$component,
ld_all = "Learning Deprivation",
sd_all = "Schooling Deprivation"
)
# Plot
p <- ggplot() +
# Stacked components
geom_area(
data = df_long,
aes(x = year_assessment, y = value, fill = component),
alpha = 0.7
) +
# Learning poverty line
geom_line(
data = df_country,
aes(x = year_assessment, y = lp_all, color = "Learning Poverty"),
linewidth = 1.5
) +
# LD points with assessment shapes
geom_point(
data = df_country,
aes(x = year_assessment, y = ld_all, shape = test),
size = 3,
color = "black"
) +
scale_fill_manual(
name = "",
values = c(
"Learning Deprivation" = "#D55E00",
"Schooling Deprivation" = "#009E73"
)
) +
scale_color_manual(
name = "",
values = c("Learning Poverty" = "#0072B2")
) +
scale_y_continuous(
labels = label_percent(scale = 1),
expand = expansion(mult = 0.05)
) +
labs(
title = unique(df_country$country_name),
subtitle = "Learning Poverty Decomposition",
x = "Assessment Year",
y = "Share of Children (%)",
shape = "Assessment"
) +
theme_classic(base_size = 14) +
theme(
legend.position = "bottom",
plot.title = element_text(face = "bold", size = 18)
)
p
