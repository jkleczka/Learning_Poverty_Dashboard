# Sample Line Plot for LP
library(tidyverse)
# Load data
df_country <- LP_filtered %>%
filter(countrycode == "IND")   # <-- change this
# Plot
ggplot(df_country, aes(x = release_year)) +
# Lines
geom_line(aes(y = lp_all, color = "Learning Poverty"), linewidth = 1) +
geom_line(aes(y = ld_all, color = "Learning Deprivation"), linewidth = 1) +
geom_line(aes(y = sd_all, color = "Schooling Deprivation"), linewidth = 1) +
# Points for LD with shapes by test
geom_point(
aes(y = ld_all, shape = test),
size = 3,
color = "black"
) +
scale_color_manual(
name = "Indicator",
values = c(
"Learning Poverty" = "#1b9e77",
"Learning Deprivation" = "#d95f02",
"Schooling Deprivation" = "#7570b3"
)
) +
labs(
title = unique(df_country$country_name),
x = "Assessment Year",
y = "Percentage",
shape = "Assessment Type"
) +
theme_minimal()
Sample Line Plot for LP
library(tidyverse)
library(scales)
# Filter to one country
df_country <- LP_filtered %>%
filter(countrycode == "BRA") %>%   # change country
arrange(year_assessment)
# Plot
p <- ggplot(df_country, aes(x = year_assessment)) +
# Lines
geom_line(aes(y = lp_all, color = "Learning Poverty"), linewidth = 1.3) +
geom_line(aes(y = ld_all, color = "Learning Deprivation"), linewidth = 1.3) +
geom_line(aes(y = sd_all, color = "Schooling Deprivation"), linewidth = 1.3) +
# Points for LD (shape varies by test)
geom_point(
aes(y = ld_all, shape = test),
size = 3.5,
stroke = 1,
color = "black"
) +
# Color palette
scale_color_manual(
name = "",
values = c(
"Learning Poverty" = "#0072B2",
"Learning Deprivation" = "#D55E00",
"Schooling Deprivation" = "#009E73"
)
) +
# Axis formatting
scale_y_continuous(
labels = label_percent(scale = 1),
limits = c(0,100)
) +
labs(
title = unique(df_country$country_name),
subtitle = "Learning Poverty and its Components Over Time",
x = "Assessment Year",
y = "Share of Children (%)",
shape = "Assessment"
) +
theme_classic(base_size = 14) +
theme(
legend.position = "bottom",
legend.box = "vertical",
legend.title = element_text(size = 12),
legend.text = element_text(size = 11),
plot.title = element_text(size = 18, face = "bold"),
plot.subtitle = element_text(size = 13),
axis.title = element_text(size = 13),
axis.text = element_text(size = 11)
)
p
