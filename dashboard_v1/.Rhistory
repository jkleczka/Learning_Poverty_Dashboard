# mod_projectInfo.R
# ======================
# Module for collecting general project information
# UI Function ----
projectInfoUI <- function(id) {
ns <- NS(id)
tagList(
box(
title = "General Project Information",
width = 12,
solidHeader = TRUE,
status = "primary",
collapsible = TRUE,
column(6,
textInput(ns("pcode"), "P-Code", placeholder = "Enter project code"),
textInput(ns("username"), "User Name", placeholder = "Enter your name")
),
column(6,
selectInput(ns("country"), "Select Country",
choices = c("Kenya", "Nigeria", "Ethiopia", "India",
"Bangladesh", "Brazil", "Peru", "Vietnam", "Philippines")),
selectInput(ns("region"), "Select Region",
choices = c("Africa", "South Asia", "Latin Amer.", "East Asia")),
numericInput(ns("hired"), "Total People Hired for the Project", value = NA, min = 0)
)
)
)
}
# Server Function ----
projectInfoServer <- function(id) {
moduleServer(id, function(input, output, session) {
# Return reactive list of project information
project_data <- reactive({
list(
pcode = input$pcode,
username = input$username,
country = input$country,
region = input$region,
hired = input$hired
)
})
return(project_data)
})
}
source('run_app.R')
View(projectInfoUI)
