ece <- figure_5_data %>%
filter(idgrade == 4) %>%
filter(countrycode == selected_country) %>%
transmute(
`Math|Attended ECE` = round(m_bmp_ece_math1 * 100, 1),
`Math|Did Not Attend ECE` = round(m_bmp_ece_math0 * 100, 1),
`Science|Attended ECE` = round(m_bmp_ece_scie1 * 100, 1),
`Science|Did Not Attend ECE` = round(m_bmp_ece_scie0 * 100, 1)
) %>%
pivot_longer(cols = everything(), names_to = "group", values_to = "bmp") %>%
separate(group, into = c("Subject", "ECE_Status"), sep = "\\|") %>%
mutate(Label = paste(Subject, ECE_Status, sep = "\n"))
# Plot with no legend and combined x-axis labels
fig5 <- ggplot(ece, aes(x = Label, y = bmp, fill = ECE_Status)) +
geom_bar(stat = "identity", width = 0.6) +
geom_text(aes(label = paste0(bmp, "%")), vjust = -0.5, size = 4) +
scale_fill_manual(values = c("Attended ECE" = "#b7e1dc", "Did Not Attend ECE" = '#c735f5')) +
labs(title = "Grade 4 BMP by ECE Status and Subject") +
theme_minimal() +
theme(
panel.grid = element_blank(),
axis.text.x = element_text(size = 12),
axis.title = element_blank(),
legend.position = "none"
) +
ylim(0, max(ece$bmp, na.rm = TRUE) + 10)
# Print the plot
fig5
