##NOTE: REMEMBER TO CHANGE MATH AND SCIENCE AS COMPARED TO GRADE 4 and GRADE 8
# Load and prepare image
img_grade4 <- readPNG(file.path(inputfolder, "Grade4.png"))
g_grade4 <- rasterGrob(img_grade4, width = unit(0.40, "inches"),
height = unit(0.40, "inches"), interpolate = TRUE)
### Load and process data for Grade 4 and Grade 8
figure_6_data <- read.csv(file.path(folder, "081_input_data/all_results_timss.csv"))
#Grade 4 - Math
plot_data_g4 <- figure_6_data %>%
filter(idgrade == 4, countryname != "") %>%
select(countrycode, countryname, reg, m_tch_t_minperweekmath) %>%
mutate(m_tch_t_minperweekmath = round(m_tch_t_minperweekmath)) %>%
filter(!is.na(m_tch_t_minperweekmath))
selected_data_g4 <- plot_data_g4 %>%
filter(countrycode == selected_country)
#Grade 8
plot_data_g8 <- figure_6_data %>%
filter(idgrade == 8, countryname != "") %>%
select(countrycode, countryname, reg, m_tch_t_minperweekmath) %>%
mutate(m_tch_t_minperweekmath = round(m_tch_t_minperweekmath)) %>%
filter(!is.na(m_tch_t_minperweekmath))
selected_data_g8 <- plot_data_g8 %>%
filter(countrycode == selected_country)
### Calculate medians
#Grade 4
medians_g4 <- plot_data_g4 %>%
summarise(
global = median(m_tch_t_minperweekmath),
regional = median(m_tch_t_minperweekmath[reg == selected_data_g4$reg[[1]]])
)
pos_region_g4 <- ifelse(medians_g4$regional > medians_g4$global,
medians_g4$regional + 15,
medians_g4$regional - 15)
#Grade 8
medians_g8 <- plot_data_g8 %>%
summarise(
global = median(m_tch_t_minperweekmath),
regional = median(m_tch_t_minperweekmath[reg == selected_data_g8$reg[[1]]])
)
pos_region_g8 <- ifelse(medians_g8$regional > medians_g8$global,
medians_g8$regional + 15,
medians_g8$regional - 15)
### Plot
#Grade 4 - Math
fig6.1 <- ggplot(plot_data_g4, aes(x = reorder(countryname, -m_tch_t_minperweekmath),
y = m_tch_t_minperweekmath, fill = reg)) +
geom_bar(stat = "identity", alpha = 0.3) +
geom_bar(data = selected_data_g4, stat = "identity", alpha = 1, color = "grey50") +
geom_text(data = selected_data_g4, aes(label = m_tch_t_minperweekmath),
vjust = -0.2, color = "black", size = 5.5) +
geom_hline(yintercept = c(medians_g4$global, medians_g4$regional),
color = "grey", linetype = "dashed", size = 0.8) +
scale_fill_manual(values = c('#c735f5', '#be94e9', '#b6d3df', '#f9ddbe', '#f1bb9f', '#ff87a2')) +
scale_x_discrete(expand = c(0, 0.5)) +
coord_cartesian(clip = "off") +
labs(
title = "Minutes of Instructional Time per Week - Math",
x = "",
y = "Total time (mins)"
) +
theme_minimal() +
theme(
panel.grid = element_blank(),
axis.text.x = element_text(size = 10, angle = 90, hjust = 1, vjust = 0.5),
axis.text.y = element_text(size = 12),
axis.title.x = element_text(size = 14),
axis.title.y = element_text(size = 14, margin = margin(r = 15)),
plot.title = element_text(size = 16, hjust = 0.5, face = "bold", margin = margin(b = 20)),
legend.position = "bottom",
legend.direction = "horizontal",
legend.box = "horizontal",
legend.text = element_text(size = 12),
legend.title = element_blank(),
legend.spacing.x = unit(0.5, 'cm'),
plot.margin = unit(c(1, 4, 1, 1), "cm")
) +
guides(fill = guide_legend(nrow = 1)) +
annotation_custom(
grob = textGrob(
label = paste("Global Median:", as.integer(medians_g4$global)),
hjust = 1.5,
gp = gpar(cex = 1, col = "grey50")
),
ymin = medians_g4$global + 15, ymax = medians_g4$global + 15, xmin = 45, xmax = 45
) +
annotation_custom(
grob = textGrob(
label = paste(selected_data_g4$reg, "Median:", as.integer(medians_g4$regional)),
hjust = 1.5,
gp = gpar(cex = 1, col = "grey50")
),
ymin = pos_region_g4, ymax = pos_region_g4, xmin = 45, xmax = 45
) +
# Add Grade 4 logo in top-right corner (fixed version)
annotation_custom(
grob = g_grade4,
xmin = max(as.numeric(factor(plot_data_g4$countryname))) + 0.5,  # Right side of plot
xmax = max(as.numeric(factor(plot_data_g4$countryname))) + 2,    # Further right
ymin = max(plot_data_g4$m_tch_t_minperweekmath, na.rm = TRUE) * 1.50,  # Above top bar
ymax = max(plot_data_g4$m_tch_t_minperweekmath, na.rm = TRUE) * 1.50   # Higher position
)
#Grade 4 - Science
fig6.2 <- ggplot(plot_data_g8, aes(x = reorder(countryname, -m_tch_t_minperweekmath),
y = m_tch_t_minperweekmath, fill = reg)) +
geom_bar(stat = "identity", alpha = 0.3) +
geom_bar(data = selected_data_g8, stat = "identity", alpha = 1, color = "grey50") +
geom_text(data = selected_data_g8, aes(label = m_tch_t_minperweekmath),
vjust = -0.2, color = "black", size = 5.5) +
geom_hline(yintercept = c(medians_g8$global, medians_g8$regional),
color = "grey", linetype = "dashed", size = 0.8) +
scale_fill_manual(values = c('#c735f5', '#be94e9', '#b6d3df', '#f9ddbe', '#f1bb9f', '#ff87a2')) +
scale_x_discrete(expand = c(0, 0.5)) +
coord_cartesian(clip = "off") +
labs(
title = "Minutes of Instructional Time per Week - Science",
x = "",
y = "Total time (mins)"
) +
theme_minimal() +
