figure_7_data <- read.csv(file.path(folder, "081_input_data/all_results_timss.csv"))
# Select relevant columns and filter for selected country
factors_data <- figure_7_data %>%
filter(idgrade == 4)  %>%
select(countrycode, starts_with("m_sch_c_shortage")) %>%
filter(countrycode == selected_country) %>%
pivot_longer(cols = starts_with("m_sch_c_shortage"),
names_to = "factor_code",
values_to = "share_responding_alot") %>%
mutate(
factor = recode(factor_code,
"m_sch_c_shortagea4" = "Instructional Materials",
"m_sch_c_shortageb4" = "School Supplies",
"m_sch_c_shortagec4" = "School Buildings",
"m_sch_c_shortaged4" = "Heating Systems",
"m_sch_c_shortagee4" = "Instructional Space",
"m_sch_c_shortagef4" = "Technological Staff",
"m_sch_c_shortageg4" = "Audio Visual Resources",
"m_sch_c_shortageh4" = "Digital Devices",
"m_sch_c_shortagei4" = "Resources for Disabled Students"
)
)
# Sort data by value
factors_data <- factors_data %>%
arrange(desc(share_responding_alot))
# Create packing
factors_data$adjusted_size <- factors_data$share_responding_alot^1.75
factors_data$packing <- circleProgressiveLayout(factors_data$adjusted_size, sizetype = "area")
vertices <- circleLayoutVertices(factors_data$packing, npoints = 50)
vertices$fill_value <- rep(factors_data$share_responding_alot, each = 51)
# Add combined label for centered text
factors_data$label <- paste0(factors_data$factor, "\n", round(factors_data$share_responding_alot * 100), "%")
# Plot
ggplot() +
geom_polygon(
data = vertices,
aes(x, y, group = id, fill = fill_value),
color = "black", size = 0.1, alpha = 0.8
) +
# Centered label (factor + percentage)
geom_text(
data = factors_data,
aes(x = packing$x, y = packing$y, label = label),
size = 3, color = "black", family = "sans", lineheight = 0.9
) +
scale_fill_viridis_c(option = "plasma", name = "% Responding 'A Lot'") +
coord_equal() +
theme_void() +
theme(
legend.position = "none",
plot.margin = unit(rep(0.5, 4), "cm"),
plot.title = element_text(size = 16, face = "bold"),
plot.subtitle = element_text(size = 12),
plot.caption = element_text(size = 8, hjust = 1)
) +
labs(
title = "Perceived Shortages in School Resources",
subtitle = paste0("Country: ", selected_country),
caption = "Source: TIMSS"
)
# --- DATA LOAD --- #
figure_8_data <- read.csv(file.path(folder, "081_input_data/all_results_timss.csv"))
#Note: it does seem like we have data on this question for anything above grade 4/5. JK to double check that this is true
# --- PROCESS PARENT RESPONSE DATA --- #
perc <- figure_8_data %>%
filter(idgrade == 4) %>%
filter(countrycode == selected_country) %>%
select(learningloss_notatall, learningloss_somewhat, learningloss_alot) %>%
mutate(
learningloss_na = 1 - rowSums(across(everything()), na.rm = TRUE)
) %>%
pivot_longer(everything(), names_to = "level", values_to = "share") %>%
mutate(
share = round(share * 100, 1),
label = recode(level,
"learningloss_notatall" = "Not at All",
"learningloss_somewhat" = "Somewhat",
"learningloss_alot" = "A Lot",
"learningloss_na" = "Not Applicable"
),
order = factor(label, levels = c("Not at All", "Somewhat", "A Lot", "Not Applicable"))
)
# --- FIGURE 8: STACKED BAR CHART --- #
fig8 <- ggplot(perc, aes(x = "", y = share, fill = order)) +
geom_col(width = 0.8) +
geom_text(
aes(label = paste0(label, ": ", share, "%")),
position = position_stack(vjust = 0.5),
size = 5.5, color = "black"
) +
scale_fill_manual(
values = c('#e6ffdd', '#b9b5e4', '#c735f5', 'grey'),
drop = FALSE
) +
theme_void() +
theme(legend.position = "none")
fig8
# Load data
figure_x_data <- read.csv(file.path(folder, "081_input_data/all_results_timss.csv"), header = TRUE)
# Filter for grade 4/5
figure_x_data <- figure_x_data %>%
filter(idgrade == 4)
# Convert Instructional Minutes Per Week to Per Day
figure_x_data$mins_per_day_math <- figure_x_data$m_tch_t_minperweekmath/7
figure_x_data$mins_per_day_scie <- figure_x_data$m_tch_t_minperweeksci/7
# Generate total instructional minutes per year
figure_x_data$yearly_mins_math <- figure_x_data$mins_per_day_math * figure_x_data$m_sch_c_daysperyear
figure_x_data$yearly_mins_scie <- figure_x_data$mins_per_day_scie * figure_x_data$m_sch_c_daysperyear
# Plot
# Dummy dataset for legend only
legend_data <- figure_x_data[!duplicated(figure_x_data$region), ]
legend_data$yearly_mins_math <- Inf  # Off the plot
legend_data$m_score_math_2023 <- Inf # Off the plot
ggplot(figure_x_data, aes(x = yearly_mins_math, y = m_score_math_2023, color = region)) +
# Dummy points for legend only
geom_point(data = legend_data, aes(x = yearly_mins_math, y = m_score_math_2023), show.legend = TRUE) +
# Country codes as text markers
geom_text(aes(label = countrycode), fontface = "plain", alpha = 0.7, show.legend = FALSE) +
# Bold label for selected country
geom_text(
data = subset(figure_x_data, countrycode == selected_country),
aes(label = countrycode),
color = "black", fontface = "bold", show.legend = FALSE
) +
scale_color_viridis_d(option = "plasma", begin = 0, end = 0.85) +
guides(color = guide_legend(override.aes = list(shape = 16, size = 3))) +  # circles in legend only
labs(
x = "Yearly Minutes of Math Instruction",
y = "Math Score",
color = "Region"
) +
theme_minimal() +
theme(
legend.position = "right",
plot.title = element_text(hjust = 0.5)
) +
ggtitle("Math Scores vs. Instruction Time by Region")
library(shiny); source('~/GitHub/Learning_Poverty_Dashboard/proof_of_concept/run_app.R')
