Subgroup_Category = case_when(
str_detect(subgroup, "male") ~ "Student Gender",
str_detect(subgroup, "qescs") ~ "Student Socioeconomic Status",
str_detect(subgroup, "urban") ~ "School Location"
),
Subgroup_Label = case_when(
subgroup == "male=0" ~ "Girls",
subgroup == "male=1" ~ "Boys",
subgroup == "qescs=1" ~ "Q1",
subgroup == "qescs=5" ~ "Q5",
subgroup == "urban=0" ~ "Rural",
subgroup == "urban=1" ~ "Urban"
),
BMP = (1 - m_sdg411_math) * 100
)
# Prepare wide datasets
df_scores <- TIMSS_filt %>%
select(Subgroup_Category, Subgroup_Label, m_score_timss_scie) %>%
pivot_wider(names_from = Subgroup_Label, values_from = m_score_timss_scie) %>%
mutate(Subgroup_Category = factor(Subgroup_Category, levels = c("School Location", "Student Socioeconomic Status", "Student Gender")))
# Dynamically determine x-axis ranges
score_values <- unlist(df_scores[ , names(df_scores) %in% c("Girls", "Boys", "Q1", "Q5", "Rural", "Urban")])
score_range <- c(floor(min(score_values, na.rm = TRUE) - 5), ceiling(max(score_values, na.rm = TRUE) + 5))
# Plotting function
plot_bubbles <- function(df, value_label, x_range, decimals = 0) {
format_label <- function(x) sprintf(paste0("%.", decimals, "f"), x)
gg <- ggplot(df, aes(y = Subgroup_Category))
subgroup_sets <- list(c("Girls", "Boys"), c("Q1", "Q5"), c("Rural", "Urban"))
colors <- c("#F8E71C", "#00BFC4")
for (set in subgroup_sets) {
if (all(set %in% names(df))) {
gg <- gg +
geom_segment(aes_string(x = set[1], xend = set[2], yend = "Subgroup_Category"),
color = "gray60", size = 1, na.rm = TRUE) +
geom_point(aes_string(x = set[1]), color = colors[1], size = 7, na.rm = TRUE) +
geom_point(aes_string(x = set[2]), color = colors[2], size = 7, na.rm = TRUE) +
geom_text(aes_string(x = set[1], label = paste0("format_label(", set[1], ")")),
size = 2.5, na.rm = TRUE) +
geom_text(aes_string(x = set[2], label = paste0("format_label(", set[2], ")")),
size = 2.5, na.rm = TRUE) +
geom_text(aes_string(x = set[1], label = shQuote(set[1])),
vjust = -2.2, size = 2.5, na.rm = TRUE) +
geom_text(aes_string(x = set[2], label = shQuote(set[2])),
vjust = -2.2, size = 2.5, na.rm = TRUE)
}
}
gg +
scale_x_continuous(limits = x_range) +
labs(x = value_label, y = NULL) +
theme_minimal(base_size = 14)
}
# Generate plots
plot_scores <- plot_bubbles(df_scores, "Mean Scores", x_range = score_range, decimals = 0)
# Combine
plot_scores
# Load data
figure_5_data <- read.csv(file.path(folder, "081_input_data/all_results_timss.csv"), header = TRUE)
# Filter and reshape for Grade 4 only
